LITELLM_API_KEY=your-tritonai-api-key-here
LITELLM_BASE_URL=https://tritonai-api.ucsd.edu
LITELLM_MODEL=claude-sonnet-4-6
# Vercel Blob store token — required for client-direct CV uploads.
# Provisioned automatically in production when the Blob store is linked.
BLOB_READ_WRITE_TOKEN=your-vercel-blob-token-here
# Shared secret used to authenticate cross-function calls between
# /api/upload → /api/slice → /api/finalize. Generate with:
#   openssl rand -hex 32
INTERNAL_API_SECRET=replace-with-random-32-byte-hex
# Optional: set automatically by Vercel when Protection Bypass for Automation
# is enabled. Internal cross-function fetches include it when present.
VERCEL_AUTOMATION_BYPASS_SECRET=your-vercel-automation-bypass-secret
